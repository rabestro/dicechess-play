# --- install-time ---
# GitHub PAT with read:packages — needed to install @rabestro/dicechess-engine and
# @lichess-org/chessground from GitHub Packages (see .npmrc). Export it before install:
#   export NODE_AUTH_TOKEN=ghp_xxx && npm install
NODE_AUTH_TOKEN=

# --- runtime (Vite, client-exposed) ---
# Base URL of the ingest GATEWAY (Koyeb), which holds the analytics Bearer token and
# forwards finished games to sync.jc.id.lv. The browser never holds the token.
# Leave empty in dev to disable posting (games still save to IndexedDB).
VITE_INGEST_GATEWAY_URL=

# Base URL of play-api — the authoritative human-vs-human server (e.g. http://localhost:8080).
# Leave empty to disable live play (the /live routes).
VITE_PLAY_API_URL=
